# Copy this to .env and fill in your values

# Required — the upstream server this proxy forwards to
PROXY_ORIGIN=http://your-origin-server.com

# Server port (default: 8081)
PORT=8081

# Redis connection (required)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0

# Cache settings
CACHE_KEY=CACHE_KEY
RESPONSE_TTL=1
